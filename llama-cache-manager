#!/usr/bin/env bash

set -euo pipefail

SCRIPT_NAME="$(basename "$0")"
VERSION="0.1.0"

resolve_script_path() {
	local source_path="${BASH_SOURCE[0]:-$0}"

	if command -v realpath >/dev/null 2>&1; then
		realpath "$source_path"
	else
		readlink -f "$source_path"
	fi
}

SCRIPT_PATH="$(resolve_script_path)"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
DEFAULT_CACHE_DIR="${LLAMA_CACHE:-${HF_HOME:-$HOME/.cache}/llama.cpp}"
DEFAULT_CACHE_FALLBACK="${HF_HOME:-$HOME/.cache}/llama.cpp"
DEFAULT_CACHE_HELP_FALLBACK="${DEFAULT_CACHE_FALLBACK/#$HOME/\~}"
DEFAULT_CACHE_HELP="LLAMA_CACHE or $DEFAULT_CACHE_HELP_FALLBACK"

handle_sigpipe() {
	exit 0
}

trap handle_sigpipe PIPE

safe_printf() {
	/usr/bin/printf "$@" 2>/dev/null || exit 0
}

string_length() {
	printf '%s' "$1" | wc -m | tr -d ' '
}

init_colors() {
	COLOR_RESET=""
	COLOR_MODEL=""
	COLOR_TOTAL_SIZE=""
	COLOR_QUANT=""
	COLOR_MMPROJ=""
	COLOR_SIZE=""

	if [ -n "${NO_COLOR:-}" ]; then
		return 0
	fi

	if [ ! -t 1 ]; then
		return 0
	fi

	COLOR_RESET=$'\033[0m'
	COLOR_MODEL=$'\033[1m'
	COLOR_TOTAL_SIZE=$'\033[36m'
	COLOR_QUANT=$'\033[34m'
	COLOR_MMPROJ=$'\033[33m'
	COLOR_SIZE=$'\033[90m'
}

paint() {
	local color="$1"
	local text="$2"

	if [ -z "$color" ]; then
		printf '%s' "$text"
	else
		printf '%s%s%s' "$color" "$text" "$COLOR_RESET"
	fi
}

usage() {
	cat <<EOF
Usage:
  $SCRIPT_NAME [OPTIONS] <command>

Options:
  -c DIR, --cache-dir DIR  Cache root. Default: $DEFAULT_CACHE_HELP
  -h, --help               Show this help
  -V, --version            Show version

Commands:
  completions             Print shell completion script to stdout
  help                    Show global or command-specific help
  ls, list                List cached models and artifacts
  rm, remove              Remove MODEL or MODEL:QUANT from the cache
EOF
}

print_version() {
	printf '%s v%s\n' "$SCRIPT_NAME" "$VERSION"
}

usage_list() {
	cat <<EOF
Usage:
  $SCRIPT_NAME {ls|list} [FILTER...]

List cached models grouped by snapshot, with deduplicated model totals.
EOF
}

usage_rm() {
	cat <<EOF
Usage:
  $SCRIPT_NAME {rm|remove} [-n|--dry-run] [-f|--force] MODEL[:QUANT]

Options:
  -n, --dry-run            Print actions without deleting
  -f, --force              Delete without confirmation
EOF
}

usage_completions() {
	cat <<EOF
Usage:
  $SCRIPT_NAME completions {bash|zsh|fish}
EOF
}

usage_complete() {
	cat <<EOF
Usage:
  $SCRIPT_NAME __complete {commands|rm|filters}
EOF
}

die() {
	echo "error: $*" >&2
	exit 1
}

have_cmd() {
	command -v "$1" >/dev/null 2>&1
}

resolve_path() {
	if have_cmd realpath; then
		realpath "$1"
	else
		readlink -f "$1"
	fi
}

file_size_bytes() {
	if stat -c '%s' "$1" >/dev/null 2>&1; then
		stat -c '%s' "$1"
	else
		stat -f '%z' "$1"
	fi
}

file_mtime_epoch() {
	if stat -c '%Y' "$1" >/dev/null 2>&1; then
		stat -c '%Y' "$1"
	else
		stat -f '%m' "$1"
	fi
}

format_local_timestamp() {
	local epoch="$1"

	if date -d "@$epoch" '+%Y-%m-%d %H:%M' >/dev/null 2>&1; then
		date -d "@$epoch" '+%Y-%m-%d %H:%M'
	else
		date -r "$epoch" '+%Y-%m-%d %H:%M'
	fi
}

current_time_epoch() {
	date '+%s'
}

format_cached_age() {
	local now_epoch="$1"
	local cached_epoch="$2"
	local cached_at age_days day_label

	if [ "$cached_epoch" -gt "$now_epoch" ]; then
		age_days=0
	else
		age_days=$(((now_epoch - cached_epoch) / 86400))
	fi

	cached_at="$(format_local_timestamp "$cached_epoch")"
	day_label="days"
	if [ "$age_days" -eq 1 ]; then
		day_label="day"
	fi

	printf 'cached %s %s ago (on %s)' "$age_days" "$day_label" "$cached_at"
}

human_size() {
	local bytes="$1"
	local units=(B KiB MiB GiB TiB)
	local unit=0
	local whole="$bytes"
	local frac=0

	while [ "$whole" -ge 1024 ] && [ "$unit" -lt 4 ]; do
		frac=$(((whole % 1024) * 10 / 1024))
		whole=$((whole / 1024))
		unit=$((unit + 1))
	done

	printf '%s.%s%s' "$whole" "$frac" "${units[$unit]}"
}

confirm() {
	local prompt="$1"

	if [ "$FORCE" -eq 1 ]; then
		return 0
	fi

	printf '%s [y/N] ' "$prompt" >&2
	read -r answer
	case "$answer" in
	y | Y | yes | YES)
		return 0
		;;
	*)
		return 1
		;;
	esac
}

delete_path() {
	local path="$1"

	if [ "$DRY_RUN" -eq 1 ]; then
		printf 'DRY-RUN rm %s\n' "$path"
	else
		rm -rf -- "$path"
		printf 'deleted %s\n' "$path"
	fi
}

delete_empty_dir() {
	local path="$1"

	if [ "$DRY_RUN" -eq 1 ]; then
		printf 'DRY-RUN rmdir %s\n' "$path"
	else
		rmdir -- "$path"
		printf 'deleted %s\n' "$path"
	fi
}

model_dir_path() {
	printf '%s/%s' "$CACHE_DIR" "$1"
}

display_model_ref() {
	local model="$1"

	if printf '%s\n' "$model" | grep -Eq '^models--[^/]+--.+$'; then
		printf '%s\n' "$model" | sed -E 's/^models--([^/]+)--(.+)$/\1\/\2/'
	else
		printf '%s\n' "$model"
	fi
}

normalize_model_ref() {
	local ref="$1"

	if printf '%s\n' "$ref" | grep -Eq '^models--[^/]+--.+$'; then
		printf '%s\n' "$ref"
		return 0
	fi

	if printf '%s\n' "$ref" | grep -Eq '^[^/]+/.+$'; then
		printf 'models--%s\n' "$(printf '%s\n' "$ref" | sed 's/\//--/')"
		return 0
	fi

	die "invalid model reference: $ref"
}

split_model_quant_ref() {
	local ref="$1"
	local model_part quant_part

	if printf '%s\n' "$ref" | grep -q ':'; then
		model_part="${ref%%:*}"
		quant_part="${ref#*:}"
	else
		model_part="$ref"
		quant_part=""
	fi

	printf '%s\n%s\n' "$model_part" "$quant_part"
}

model_base_name() {
	local model="$1"
	local display_ref repo_name

	display_ref="$(display_model_ref "$model")"
	repo_name="${display_ref#*/}"
	printf '%s\n' "${repo_name%-GGUF}"
}

extract_quant_label() {
	local model="$1"
	local file_name="$2"
	local base_name="${2%.gguf}"
	local model_base

	model_base="$(model_base_name "$model")"

	case "$base_name" in
	mmproj-*)
		printf '%s\n' "${base_name#mmproj-}"
		;;
	"$model_base"-*)
		printf '%s\n' "${base_name#"$model_base"-}"
		;;
	*)
		printf '%s\n' "-"
		;;
	esac
}

artifact_label() {
	local model="$1"
	local file_name="$2"
	local quant

	quant="$(extract_quant_label "$model" "$file_name")"

	case "$file_name" in
	mmproj-*.gguf)
		printf 'mmproj %s\n' "$quant"
		;;
	*)
		if [ "$quant" = "-" ]; then
			printf '%s\n' "$file_name"
		else
			printf '%s\n' "$quant"
		fi
		;;
	esac
}

artifact_color() {
	local label="$1"

	case "$label" in
	mmproj*)
		printf '%s' "$COLOR_MMPROJ"
		;;
	*)
		printf '%s' "$COLOR_QUANT"
		;;
	esac
}

artifact_sort_key() {
	local label="$1"

	case "$label" in
	mmproj*)
		printf '1|%s\n' "$label"
		;;
	*)
		printf '0|%s\n' "$label"
		;;
	esac
}

contains_ci() {
	local haystack="$1"
	local needle="$2"

	haystack="$(printf '%s' "$haystack" | tr '[:upper:]' '[:lower:]')"
	needle="$(printf '%s' "$needle" | tr '[:upper:]' '[:lower:]')"

	case "$haystack" in
	*"$needle"*)
		return 0
		;;
	*)
		return 1
		;;
	esac
}

matches_filter() {
	local model_ref="$1"
	local label="$2"
	local filter="$3"
	local full_ref="${model_ref}:${label}"

	case "$filter" in
	:*)
		contains_ci "$label" "${filter#:}"
		;;
	*:*)
		contains_ci "$full_ref" "$filter"
		;;
	*)
		contains_ci "$model_ref" "$filter"
		;;
	esac
}

matches_filters() {
	local model_ref="$1"
	local label="$2"
	local filter

	if [ "$#" -eq 2 ]; then
		return 0
	fi

	shift 2
	for filter in "$@"; do
		if matches_filter "$model_ref" "$label" "$filter"; then
			return 0
		fi
	done

	return 1
}

complete_commands() {
	printf '%s\n' help ls list rm remove
}

complete_refs() {
	local mode="$1"
	local model_dir snapshot_dir model_ref org_ref
	local entry_path entry_name label

	while read -r model_dir; do
		snapshot_dir="$model_dir/snapshots"
		[ -d "$snapshot_dir" ] || continue
		model_ref="$(display_model_ref "$(basename "$model_dir")")"
		org_ref="${model_ref%%/*}"

		case "$mode" in
		filters)
			printf '%s\n' "$org_ref"
			printf '%s\n' "$model_ref"
			;;
		rm)
			printf '%s\n' "$model_ref"
			;;
		esac

		while read -r entry_path; do
			entry_name="$(basename "$entry_path")"
			label="$(artifact_label "$model_ref" "$entry_name")"

			case "$label" in
			*" "*) continue ;;
			esac

			case "$mode" in
			filters)
				printf ':%s\n' "$label"
				printf '%s:%s\n' "$model_ref" "$label"
				;;
			rm)
				printf '%s:%s\n' "$model_ref" "$label"
				;;
			esac
		done < <(find "$snapshot_dir" -mindepth 2 -maxdepth 2 -type l -name '*.gguf' | sort)
	done < <(find "$CACHE_DIR" -mindepth 1 -maxdepth 1 -type d -name 'models--*' | sort)
}

run_complete() {
	local mode="${1:-}"

	case "$mode" in
	commands)
		complete_commands | sort -u
		;;
	rm)
		complete_refs rm | sort -u
		;;
	filters)
		complete_refs filters | sort -u
		;;
	-h|--help|"")
		usage_complete
		;;
	*)
		die "unknown completion mode: $mode"
		;;
	esac
}

print_completion_script() {
	local shell_name="$1"
	local path

	case "$shell_name" in
	bash)
		path="$SCRIPT_DIR/completions/llama-cache-manager.bash"
		;;
	zsh)
		path="$SCRIPT_DIR/completions/_llama-cache-manager"
		;;
	fish)
		path="$SCRIPT_DIR/completions/llama-cache-manager.fish"
		;;
	*)
		die "unknown shell: $shell_name"
		;;
	esac

	[ -f "$path" ] || die "completion script not found: $path"
	cat -- "$path"
}

short_id() {
	printf '%s\n' "${1:0:8}"
}

short_revision() {
	printf '%s\n' "${1:0:7}"
}

describe_snapshot_count() {
	local count="$1"

	if [ "$count" -eq 1 ]; then
		printf '1 snapshot'
	else
		printf '%s snapshots' "$count"
	fi
}

count_unique_field() {
	local entries_file="$1"
	local field="$2"
	local label="${3:-}"
	local blob_id="${4:-}"

	awk -F '\t' -v field="$field" -v label="$label" -v blob_id="$blob_id" '
		(label == "" || $2 == label) && (blob_id == "" || $3 == blob_id) { seen[$field] = 1 }
		END {
			for (key in seen) {
				count++
			}
			print count + 0
		}
	' "$entries_file"
}

sum_unique_blob_bytes() {
	local entries_file="$1"

	awk -F '\t' '!seen[$3]++ { sum += $5 } END { print sum + 0 }' "$entries_file"
}

print_revisions_view() {
	local entries_file="$1"
	local now_epoch="$2"
	local tab=$'\t'
	local revision revision_epoch
	local label blob_id size_bytes cached_epoch size_h cached_text
	local max_label_width=0
	local prefix_text padded_prefix_text

	while IFS=$'\t' read -r _sort_key label; do
		[ -n "$label" ] || continue
		prefix_text="    - $label"
		if [ "$(string_length "$prefix_text")" -gt "$max_label_width" ]; then
			max_label_width="$(string_length "$prefix_text")"
		fi
	done < <(
		awk -F '\t' '!seen[$1 FS $2]++ { print $1 "\t" $2 }' "$entries_file" |
			sort -t "$tab" -k1,1 -k2,2
	)

	while IFS=$'\t' read -r revision revision_epoch; do
		[ -n "$revision" ] || continue
		safe_printf "%s\n" \
			"$(paint "$COLOR_MODEL" "  - $(short_revision "$revision")")"

		while IFS=$'\t' read -r _sort_key label blob_id _revision size_bytes cached_epoch; do
			[ -n "$label" ] || continue
			size_h="$(human_size "$size_bytes")"
			cached_text="$(format_cached_age "$now_epoch" "$cached_epoch")"
			padded_prefix_text="$(printf "%-*s" "$max_label_width" "    - $label")"

			safe_printf "    %s %s %s %s\n" \
				"$(paint "$(artifact_color "$label")" "${padded_prefix_text#    }")" \
				"$(paint "$COLOR_SIZE" "[$(printf '%8s' "$size_h")]")" \
				"$(paint "$COLOR_SIZE" "[$cached_text]")" \
				"$(paint "$COLOR_SIZE" "[$(short_id "$blob_id")]")"
		done < <(
			awk -F '\t' -v revision="$revision" '$4 == revision { print }' "$entries_file" |
				sort -t "$tab" -k1,1 -k2,2
		)
	done < <(
		awk -F '\t' '
			{
				if (!seen[$4] || $6 > latest[$4]) {
					latest[$4] = $6
				}
				seen[$4] = 1
			}
			END {
				for (revision in seen) {
					print revision "\t" latest[revision]
				}
			}
		' "$entries_file" |
			sort -t "$tab" -k2,2nr -k1,1
	)
}

list_models() {
	local -a filters
	local model_dir snapshot_dir model_ref entries_file
	local entry_name entry_path blob_path blob_id revision label
	local size_bytes cached_epoch
	local model_total_bytes model_total_h snapshot_count
	local now_epoch
	local first_model=1

	filters=("$@")
	now_epoch="$(current_time_epoch)"

	while read -r model_dir; do
		snapshot_dir="$model_dir/snapshots"
		[ -d "$snapshot_dir" ] || continue
		model_ref="$(display_model_ref "$(basename "$model_dir")")"
		entries_file="$(mktemp)"

		while read -r entry_path; do
			entry_name="$(basename "$entry_path")"
			revision="$(basename "$(dirname "$entry_path")")"
			blob_path="$(resolve_path "$entry_path")"
			blob_id="$(basename "$blob_path")"
			size_bytes="$(file_size_bytes "$blob_path")"
			cached_epoch="$(file_mtime_epoch "$blob_path")"
			label="$(artifact_label "$model_ref" "$entry_name")"

			if ! matches_filters "$model_ref" "$label" "${filters[@]}"; then
				continue
			fi

			printf '%s\t%s\t%s\t%s\t%s\t%s\n' \
				"$(artifact_sort_key "$label")" \
				"$label" \
				"$blob_id" \
				"$revision" \
				"$size_bytes" \
				"$cached_epoch" >>"$entries_file"
		done < <(find "$snapshot_dir" -mindepth 2 -maxdepth 2 -type l -name '*.gguf' | sort)

		if [ ! -s "$entries_file" ]; then
			rm -f "$entries_file"
			continue
		fi

		model_total_bytes="$(sum_unique_blob_bytes "$entries_file")"
		model_total_h="$(human_size "$model_total_bytes")"
		snapshot_count="$(count_unique_field "$entries_file" 4)"

		if [ "$first_model" -eq 0 ]; then
			safe_printf '\n'
		fi
		first_model=0

		safe_printf "%s %s %s\n" \
			"$(paint "$COLOR_MODEL" "$model_ref")" \
			"$(paint "$COLOR_TOTAL_SIZE" "[$(printf '%8s' "$model_total_h")]")" \
			"$(paint "$COLOR_SIZE" "[$(describe_snapshot_count "$snapshot_count")]")"

		print_revisions_view "$entries_file" "$now_epoch"

		rm -f "$entries_file"
	done < <(find "$CACHE_DIR" -mindepth 1 -maxdepth 1 -type d -name 'models--*' | sort)
}

ensure_model_exists() {
	local model="$1"
	[ -d "$(model_dir_path "$model")" ] || die "model not found: $(display_model_ref "$model")"
}

count_blob_refs() {
	local model="$1"
	local blob_path="$2"
	local skip_path="${3:-}"

	find "$(model_dir_path "$model")/snapshots" -type l -exec sh -c '
    target="$1"
    link="$2"
    skip="$3"
    if [ -n "$skip" ] && [ "$link" = "$skip" ]; then
      exit 0
    fi
    if [ "$(readlink -f "$link")" = "$target" ]; then
      printf x
    fi
  ' sh "$blob_path" {} "$skip_path" \; | wc -c | tr -d ' '
}

delete_blob_if_unreferenced() {
	local model="$1"
	local blob_path="$2"
	local skip_path="${3:-}"
	local refs

	refs="$(count_blob_refs "$model" "$blob_path" "$skip_path")"

	if [ "$refs" -eq 0 ] && [ -e "$blob_path" ]; then
		delete_path "$blob_path"
	fi
}

prune_empty_dirs() {
	local model="$1"
	local model_path
	local snapshot_dir

	model_path="$(model_dir_path "$model")"

	while read -r snapshot_dir; do
		[ -n "$snapshot_dir" ] || continue
		delete_empty_dir "$snapshot_dir"
	done < <(find "$model_path/snapshots" -mindepth 1 -type d -empty 2>/dev/null | sort -r)

	if ! find "$model_path/snapshots" -type l | grep -q .; then
		if confirm "Delete empty model directory $model_path?"; then
			delete_path "$model_path"
		fi
	fi
}

rm_quant_ref() {
	local ref="$1"
	local model="$1"
	local quant=""
	local matches=0
	local link_path blob_path entry_name
	local model_quant_ref model_ref

	model_quant_ref="$(split_model_quant_ref "$ref")"
	model_ref="$(printf '%s\n' "$model_quant_ref" | sed -n '1p')"
	quant="$(printf '%s\n' "$model_quant_ref" | sed -n '2p')"
	[ -n "$quant" ] || die "rm requires MODEL or MODEL:QUANT"
	model="$model_ref"

	model="$(normalize_model_ref "$model")"
	ensure_model_exists "$model"

	find "$(model_dir_path "$model")/snapshots" -type l -name '*.gguf' | sort | while read -r link_path; do
		entry_name="$(basename "$link_path")"
		if printf '%s\n' "$entry_name" | grep -Eq -- "-${quant}\.gguf$"; then
			printf '%s\n' "$link_path"
		fi
	done >/tmp/llama-cache-manager.matches.$$

	matches="$(wc -l </tmp/llama-cache-manager.matches.$$ | tr -d ' ')"
	[ "$matches" -gt 0 ] || {
		rm -f /tmp/llama-cache-manager.matches.$$
		die "quant not found in model: $quant"
	}

	if confirm "Delete $matches file(s) for quant $quant from $(display_model_ref "$model")?"; then
		while read -r link_path; do
			blob_path="$(resolve_path "$link_path")"
			delete_path "$link_path"
			delete_blob_if_unreferenced "$model" "$blob_path" "$link_path"
		done </tmp/llama-cache-manager.matches.$$
		prune_empty_dirs "$model"
	fi

	rm -f /tmp/llama-cache-manager.matches.$$
}

rm_model_ref() {
	local ref="$1"
	local model
	local model_path

	model="$(normalize_model_ref "$ref")"
	ensure_model_exists "$model"
	model_path="$(model_dir_path "$model")"

	if confirm "Delete full model cache $(display_model_ref "$model")?"; then
		delete_path "$model_path"
	fi
}

rm_ref() {
	local ref="$1"
	local parts model quant

	parts="$(split_model_quant_ref "$ref")"
	model="$(printf '%s\n' "$parts" | sed -n '1p')"
	quant="$(printf '%s\n' "$parts" | sed -n '2p')"

	if [ -n "$quant" ]; then
		rm_quant_ref "$ref"
	else
		rm_model_ref "$model"
	fi
}

CACHE_DIR="$DEFAULT_CACHE_DIR"
FORCE=0
DRY_RUN=0
init_colors

while [ "$#" -gt 0 ]; do
	case "$1" in
	-c | --cache-dir)
		shift
		[ "$#" -gt 0 ] || die "$1 requires a value"
		CACHE_DIR="$1"
		;;
	-h | --help)
		usage
		exit 0
		;;
	-V | --version)
		print_version
		exit 0
		;;
	*)
		break
		;;
	esac
	shift
done

[ -d "$CACHE_DIR" ] || die "cache directory not found: $CACHE_DIR"
[ "$#" -gt 0 ] || {
	list_models
	exit 0
}

case "$1" in
__complete)
	shift
	[ "$#" -eq 1 ] || die "__complete requires MODE"
	run_complete "$1"
	;;
help)
	case "${2:-}" in
	"" | -h | --help)
		usage
		;;
	completions)
		usage_completions
		;;
	ls | list)
		usage_list
		;;
	rm | remove)
		usage_rm
		;;
	*)
		die "unknown command: $2"
		;;
	esac
	;;
completions)
	shift
	case "${1:-}" in
	bash | zsh | fish)
		[ "$#" -eq 1 ] || die "completions requires SHELL"
		print_completion_script "$1"
		;;
	-h | --help | "")
		usage_completions
		;;
	*)
		die "unknown shell: $1"
		;;
	esac
	;;
ls | list)
	case "${2:-}" in
	"")
		shift
		list_models "$@"
		;;
	-h | --help)
		[ "$#" -eq 2 ] || die "list --help takes no additional arguments"
		usage_list
		;;
	*)
		shift
		list_models "$@"
		;;
	esac
	;;
rm | remove)
	shift
	while [ "$#" -gt 0 ]; do
		case "$1" in
		-n | --dry-run)
			DRY_RUN=1
			;;
		-f | --force)
			FORCE=1
			;;
		-h | --help)
			usage_rm
			exit 0
			;;
		*)
			break
			;;
		esac
		shift
	done

	[ "$#" -eq 1 ] || die "rm requires MODEL or MODEL:QUANT"
	rm_ref "$1"
	;;
-h | --help)
	usage
	;;
*)
	die "unknown command: $1"
	;;
esac
